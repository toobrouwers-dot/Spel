[autoload]

EmotionLibrary="*res://src/core/emotions/emotion_library.gd"
RunProgression="*res://src/core/run/run_progression_system.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=2340
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input]

tap_place={"deadzone": 0.5, "events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)]}
swipe_left={"deadzone": 0.5, "events": []}
swipe_right={"deadzone": 0.5, "events": []}

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
renderer/rendering_method.web="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
