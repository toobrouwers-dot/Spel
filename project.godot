; Engine configuration file.
; Generated for Godot 4.6 — FRACTURE

[configuration]

config_version=5

[application]

config/name="FRACTURE"
config/description="Emotionele grid-deckbuilder roguelite — mobile-first portrait"
config/version="0.1.0"
config/tags=PackedStringArray("mobile", "roguelite", "deckbuilder")
config/features=PackedStringArray("4.6", "Mobile")
run/main_scene="res://src/scenes/CombatScene.tscn"
boot_splash/bg_color=Color(0.05, 0.05, 0.1, 1)
